# ─── 运行模式 ─────────────────────────────────────────────
# mock = 演示模式（默认）  |  real = 正式模式（Supabase）
APP_MODE=mock

# ─── 后端 API ─────────────────────────────────────────────
API_BASE_URL=http://localhost:3010

# ─── Supabase（APP_MODE=real 时必填）──────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
