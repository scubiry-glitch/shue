# ─── Server ──────────────────────────────────────────────
PORT=3010
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=nfc_attendance

# ─── Auth Mode ────────────────────────────────────────────
# "mock"     → 使用内置Mock用户，适合本地开发
# "supabase" → 使用Supabase JWT验证，适合生产环境
AUTH_MODE=mock

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=7d

# ─── Supabase（仅 AUTH_MODE=supabase 时必填）──────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ─── NFC ──────────────────────────────────────────────────
NFC_DOMAIN=nfc.meizu.life
